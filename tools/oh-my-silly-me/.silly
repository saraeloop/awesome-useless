# oh-my-silly-me configuration
# Generated by Agent Hoot 🦉
# Last updated: 1997

# Path to oh-my-silly-me installation (DO NOT TOUCH)
export SILLY_DIR="$HOME/oh-my-silly-me"

# Theme: agent-hoot, Devcities, dial-up
export SILLY_THEME="agent-hoot"

# Plugins: tamagotchi, enya, dialup, blink, spells, overcomplicate
export SILLY_PLUGINS=(tamagotchi enya dialup spells overcomplicate)

# Identity: Agent Hoot
export SILLY_AGENT="hoot"

# Timezone: 1997
export SILLY_YEAR=1997

# Set to "true" to enable Comic Sans in terminal
# (does nothing, terminals don't support Comic Sans)
export SILLY_COMIC_SANS=true

# Number of Enya songs to play on startup
# (plays none, this is a terminal)
export SILLY_ENYA_COUNT=3

# Source the framework
if [ -f "$SILLY_DIR/silly.sh" ]; then
    source "$SILLY_DIR/silly.sh"
fi
